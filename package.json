{
  "name": "ember",
  "version": "0.1.0",
  "private": true,
  "description": "Ember — quick-service management system: POS, kitchen display and pickup board over one live order stream.",
  "scripts": {
    "dev:backend": "cd backend && mvn spring-boot:run",
    "dev:pos": "pnpm --filter @ember/pos dev",
    "dev:kitchen": "pnpm --filter @ember/kitchen dev",
    "dev:board": "pnpm --filter @ember/board dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@11.9.0"
}
